# Recommended for public VPS deploy: use hosted Supabase, or a hardened
# self-hosted Supabase with unique production secrets.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

CLOUD_RUN_URL=http://127.0.0.1:3001
CROSSBEAM_API_KEY=replace-with-a-long-random-secret
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
