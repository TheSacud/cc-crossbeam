NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<copy SUPABASE_ANON_KEY from `supabase status -o env`>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<same value as NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY>

CLOUD_RUN_URL=http://localhost:3001
CROSSBEAM_API_KEY=dev-local-crossbeam-key
CROSSBEAM_WORKER_TOKEN=dev-local-crossbeam-worker-token
SUPABASE_SERVICE_ROLE_KEY=<copy SUPABASE_SERVICE_ROLE_KEY from `supabase status -o env`>
